# ============================================================
# Steven's Ocean Hub — 環境變數範本
# 請複製此檔案並命名為 .env，填入你的真實金鑰
# cp .env.example .env
# ============================================================

# Flask
SECRET_KEY=change-this-to-a-random-secret-key
FLASK_DEBUG=0

# HackMD API
# 前往 https://hackmd.io/settings#api → 產生 Personal Access Token
HACKMD_API_TOKEN=your_hackmd_personal_access_token_here

# (選用) 預設抓取標籤篩選，留空代表抓所有筆記
# HACKMD_TAG_FILTER=blog,research

# Notion (如有使用)
NOTION_API_KEY=your_notion_api_key
NOTION_DATABASE_ID=your_notion_database_id

# LINE Notify (如有使用)
LINE_ACCESS_TOKEN=your_line_channel_access_token
LINE_USER_ID=your_line_user_id

# Email / SMTP (如有使用)
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SENDER_EMAIL=your_email@gmail.com
SENDER_PASSWORD=your_app_password
RECEIVER_EMAIL=receiver@gmail.com
